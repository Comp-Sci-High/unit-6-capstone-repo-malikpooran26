<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Key Workout Videos - FitLife</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-100 text-gray-900 font-sans">
    <!-- Hero Section -->
    <section class="bg-black text-white py-20 px-6 text-center">
        <h1 class="text-5xl font-bold mb-4">Key Workout Videos</h1>
        <p class="text-lg max-w-2xl mx-auto mb-6">
            Discover essential workout videos to build strength, lose weight, and improve your core.
        </p>
    </section>

    <!-- Video Workouts Section -->
    <section class="py-16 px-6 max-w-6xl mx-auto">
        <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h3 class="text-2xl font-semibold mb-3">Core Workout</h3>
                <p class="text-gray-600 mb-4">Strengthen your core with this effective routine.</p>
                <iframe width="100%" height="315" src="https://www.youtube.com/embed/7w8aEZX9j3c" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h3 class="text-2xl font-semibold mb-3">Strength Training</h3>
                <p class="text-gray-600 mb-4">Full body strength training to build muscle.</p>
                <iframe width="100%" height="315" src="https://www.youtube.com/embed/vc1E5CfRfz4" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h3 class="text-2xl font-semibold mb-3">Weight Loss HIIT</h3>
                <p class="text-gray-600 mb-4">High-intensity interval training for fat burn.</p>
                <iframe width="100%" height="315" src="https://www.youtube.com/embed/2pLT-olgUJs" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            </div>
        </div>
    </section>
</body>
</html>